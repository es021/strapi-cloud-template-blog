HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

# Google Cloud Storage (media uploads)
GCS_BUCKET_NAME=your-bucket-name
# Paste the full service account JSON as a single-line string
GCS_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Optional: Cloud CDN base URL in front of the GCS bucket
# e.g. https://cdn.yourdomain.com  (omit to serve directly from GCS)
CDN_BASE_URL=
